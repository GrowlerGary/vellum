# Database
DATABASE_URL="postgresql://vellum:vellum@db:5432/vellum"

# Auth (NextAuth v5) — generate with: openssl rand -base64 32
AUTH_SECRET="changeme"
AUTH_URL="http://localhost:3000"

# First admin user (created automatically on first run)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="changeme"
ADMIN_USERNAME="admin"

# Metadata APIs
TMDB_API_KEY=""                 # https://www.themoviedb.org/settings/api
IGDB_CLIENT_ID=""               # https://dev.twitch.tv/console (create app)
IGDB_CLIENT_SECRET=""
HARDCOVER_API_KEY=""            # https://hardcover.app/account/api

# AI Provider: anthropic | openai | ollama
AI_PROVIDER="anthropic"
ANTHROPIC_API_KEY=""            # https://console.anthropic.com
OPENAI_API_KEY=""               # https://platform.openai.com
OPENAI_MODEL="gpt-4o"
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3"

# Scrobble webhook secrets (generate with: openssl rand -hex 32)
TRAKT_WEBHOOK_SECRET=""
ABS_WEBHOOK_SECRET=""
STREMIO_WEBHOOK_SECRET=""
