# Database
DATABASE_URL="postgresql://vellum:vellum@db:5432/vellum"

# Auth (NextAuth v5) — generate with: openssl rand -base64 32
AUTH_SECRET="changeme"
AUTH_URL="http://localhost:3000"

# First admin user (created automatically on first run)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="changeme"
ADMIN_USERNAME="admin"

# Metadata APIs
TMDB_API_KEY=""                 # https://www.themoviedb.org/settings/api
IGDB_CLIENT_ID=""               # https://dev.twitch.tv/console (create app)
IGDB_CLIENT_SECRET=""
HARDCOVER_API_KEY=""            # https://hardcover.app/account/api
OMDB_API_KEY=""                 # https://www.omdbapi.com/apikey.aspx (for Rotten Tomatoes scores)

# AI Provider: anthropic | openai | ollama
AI_PROVIDER="anthropic"
ANTHROPIC_API_KEY=""            # https://console.anthropic.com
OPENAI_API_KEY=""               # https://platform.openai.com
OPENAI_MODEL="gpt-4o"
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3"

# Scrobble webhook secrets (generate with: openssl rand -hex 32)
TRAKT_WEBHOOK_SECRET=""
ABS_WEBHOOK_SECRET=""
STREMIO_WEBHOOK_SECRET=""

# Audiobookshelf real-time sidecar (abs-listener service)
# Leave ABS_URL empty to disable live scrobbling via Socket.IO
# ABS_TOKEN accepts either an API key (Settings → API Keys) or a personal user
# token. The sidecar calls /api/me to exchange an API key for the JWT required
# by socket auth, so either credential type works.
ABS_URL=""                      # e.g. http://192.168.1.10:13378
ABS_TOKEN=""
